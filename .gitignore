# ============================================================
# Cerberix Linux — .gitignore
# Strict rules to prevent binary / secret leaks to GitHub.
# ============================================================

# --- Build artifacts & output ---
output/
build/
*.iso
*.iso.sig
*.sha256
*.img
*.qcow2
*.vdi
*.vmdk
*.ova
*.ovf
*.pkg.tar.zst
*.pkg.tar.xz

# --- Pacman repo build output: generated, signed, and pushed by
#     `make extra-build` / `make extra-sign` / `make extra-publish`.
#     Source PKGBUILDs under packaging/cerberix-extra/<pkg>/ ARE tracked,
#     just the resolved repo dir is not. ---
packaging/repo/

# --- Generic signature files (any *.sig anywhere). Always covers
#     repo signing artifacts even if they end up outside packaging/repo/. ---
*.sig

# --- Generated site content (regenerated by make publish) ---
site/blog/
site/download/

# --- Excluded: Claude/AI agent metadata only (not your AI/Suricata code) ---
.claude/
CLAUDE.md
.aider*

# --- Secrets (never commit) ---
.gnupg/
*.gpg
*.key
*.pem
*.p12
*.pfx
*_private.*
*secret*
.env
.env.*

# --- Large binary assets (AI-generated or ambiguous-license) ---
rootfs/usr/share/backgrounds/cerberix/*.png
rootfs/usr/share/cerberix/icons/*.png
rootfs/etc/cerberix-logo.png
ChatGPT*

# --- OS / editor junk ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# --- Python / Node build artifacts ---
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
venv/
.venv/
node_modules/

# --- Docker ---
.docker/
