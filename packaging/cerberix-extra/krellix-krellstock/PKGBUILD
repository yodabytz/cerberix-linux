# Maintainer: yodabytz <hello@cerberix.org>
pkgname=krellix-krellstock
pkgver=0.1.2
pkgrel=15
arch=('x86_64' 'aarch64')
url='https://github.com/yodabytz/krellix'
license=('GPL-3.0-or-later')
pkgdesc='KrellStock: stock quote ticker and panel for Krellix (Yahoo Finance, crypto, global markets)'
depends=('krellix>=0.1.2' 'qt6-base')
makedepends=('cmake' 'ninja' 'qt6-tools' 'qt6-base')
options=('!debug')
source=("krellix-$pkgver.tar.gz"
        "fix-krellstock-symbol-loading.patch")
sha256sums=("1aef51100d57481ccf4b1ff5ee610c8c84439ef8c5632d90a02fc9d950af020c"
            "bf689204065ce36857270155a905023e64a2b846a6c101f0828aec83c230a1e1")

prepare() {
    cd "krellix-$pkgver"
    patch -Np1 -i "$srcdir/fix-krellstock-symbol-loading.patch"
}

build() {
    cd "krellix-$pkgver"
    cmake -GNinja -B build -S . \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    cmake --build build --target krellstock
}

package() {
    cd "krellix-$pkgver"
    install -Dm755 build/plugins/libkrellstock.so \
        "$pkgdir/usr/lib/krellix/plugins/libkrellstock.so"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
