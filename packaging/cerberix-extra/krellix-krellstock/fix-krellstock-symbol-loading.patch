+bool isCryptoBase(const QString &symbol)
+{
+    static const QSet<QString> crypto = {
+        QStringLiteral("BTC"), QStringLiteral("ETH"), QStringLiteral("DOGE"),
+        QStringLiteral("SOL"), QStringLiteral("XRP"), QStringLiteral("ADA"),
+        QStringLiteral("LTC"), QStringLiteral("BCH"), QStringLiteral("DOT"),
+        QStringLiteral("LINK"), QStringLiteral("XLM"), QStringLiteral("AVAX")
+    };
+    return crypto.contains(symbol);
+}
+
+bool isCryptoPair(const QString &symbol)
+{
+    const QStringList parts = symbol.split(QLatin1Char('-'));
+    return parts.size() == 2 && isCryptoBase(parts.at(0));
+}
+
+QStringList quoteCandidates(const QString &symbol)
+{
+    QStringList querySymbols{symbol};
+    if (isCryptoBase(symbol))
+        querySymbols << symbol + QStringLiteral("-USD");
+    if (QRegularExpression(QStringLiteral("^[A-Z]{1,5}\\.[A-Z]$")).match(symbol).hasMatch())
+        querySymbols << QString(symbol).replace(QLatin1Char('.'), QLatin1Char('-'));
+
+    QStringList out;
+    for (const QString &querySymbol : querySymbols) {
+        if (!out.contains(QStringLiteral("yahoo1m|") + querySymbol))
+            out << QStringLiteral("yahoo1m|") + querySymbol;
+    }
+    for (const QString &querySymbol : querySymbols) {
+        if (!out.contains(QStringLiteral("yahoo5d|") + querySymbol))
+            out << QStringLiteral("yahoo5d|") + querySymbol;
+    }
+    for (const QString &querySymbol : querySymbols) {
+        if (isCryptoPair(querySymbol) && !out.contains(QStringLiteral("coinbase|") + querySymbol))
+            out << QStringLiteral("coinbase|") + querySymbol;
+    }
+    return out;
+}
