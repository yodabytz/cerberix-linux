+
+bool isCryptoSymbol(QString symbol)
+{
+    symbol = symbol.trimmed().toUpper();
+    if (symbol.contains(QLatin1Char('/')))
+        return true;
+    const QStringList dashParts = symbol.split(QLatin1Char('-'));
+    return dashParts.size() == 2 && dashParts.at(0).size() <= 6 && dashParts.at(1).size() == 3;
+}
+
+QString twelveDataSymbol(QString symbol)
+{
+    symbol = symbol.trimmed().toUpper();
+    if (symbol.startsWith(QLatin1Char('$')))
+        symbol.remove(0, 1);
+
+    // Preserve user-entered Twelve Data crypto pairs and translate common
+    // Yahoo crypto notation used by older KrellStock configs.
+    if (symbol.contains(QLatin1Char('/')))
+        return symbol;
+    const QStringList dashParts = symbol.split(QLatin1Char('-'));
+    if (dashParts.size() == 2 && dashParts.at(0).size() <= 6 && dashParts.at(1).size() == 3)
+        return dashParts.at(0) + QLatin1Char('/') + dashParts.at(1);
+
+    // Translate common Yahoo exchange suffixes to Twelve Data's base symbols.
+    // Twelve Data resolves these base symbols to the expected primary listings
+    // in symbol search; if quote access is unavailable for a market, the UI
+    // reports that symbol as Unavailable instead of hiding it.
+    static const QHash<QString, QString> suffixes = {
+        {QStringLiteral(".L"),  QString()},
+        {QStringLiteral(".DE"), QString()},
+        {QStringLiteral(".T"),  QString()},
+        {QStringLiteral(".HK"), QString()},
+    };
+    for (auto it = suffixes.cbegin(); it != suffixes.cend(); ++it) {
+        if (symbol.endsWith(it.key()))
+            return symbol.left(symbol.size() - it.key().size()) + it.value();
+    }
+
+    return symbol;
+}
+
+double jsonNumber(const QJsonObject &obj, const QString &key)
+{
+    const QJsonValue value = obj.value(key);
+    if (value.isDouble())
+        return value.toDouble();
+    if (value.isString())
+        return value.toString().toDouble();
+    return 0.0;
+}
