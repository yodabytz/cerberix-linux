# Maintainer: yodabytz <hello@cerberix.org>
pkgname=modsentry
pkgver=1.5.1
pkgrel=1
pkgdesc="Real-time ModSecurity log monitor with iptables-based IP blocking and audit trail"
arch=('any')
url="https://github.com/yodabytz/modsentry"
license=('MIT')
depends=('python' 'whois' 'iptables')
backup=('etc/modsentry/modsentry.conf'
        'etc/modsentry/ignore-rules.conf')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz"
        "$pkgname.tmpfiles")
sha256sums=('cda93ffeb9ee5be74a1a1e83ecbcab03dd5824c8eb3ea5d127231727140b1afd'
            'SKIP')

package() {
  cd "$srcdir/$pkgname-$pkgver"

  install -Dm755 modsentry.py "$pkgdir/usr/bin/modsentry"

  install -Dm644 modsentry.conf "$pkgdir/etc/modsentry/modsentry.conf"
  install -Dm644 ignore-rules.conf "$pkgdir/etc/modsentry/ignore-rules.conf"

  install -dm755 "$pkgdir/etc/modsentry/themes"
  install -Dm644 themes/*.json -t "$pkgdir/etc/modsentry/themes/"

  install -Dm755 debug_monitor.sh "$pkgdir/usr/share/$pkgname/debug_monitor.sh"

  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

  install -Dm644 "$srcdir/$pkgname.tmpfiles" "$pkgdir/usr/lib/tmpfiles.d/$pkgname.conf"
}
