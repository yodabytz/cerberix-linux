# Maintainer: yodabytz <hello@cerberix.org>
pkgname=krellix-krellpkg
pkgver=0.1.0
pkgrel=5
arch=('x86_64' 'aarch64')
url='https://github.com/yodabytz/krellix'
license=('GPL-3.0-or-later')
pkgdesc='Krellpkg package update monitor plugin for Krellix'
depends=('krellix>=0.1.0' 'qt6-base')
optdepends=('pacman-contrib: pacman checkupdates support'
            'paru: AUR update checks'
            'yay: AUR update checks'
            'apt: apt update checks'
            'dnf: dnf update checks'
            'flatpak: Flatpak update checks'
            'snapd: Snap update checks')
makedepends=('cmake' 'ninja' 'qt6-tools' 'qt6-base')
options=('!debug')
source=("krellix-$pkgver.tar.gz")
sha256sums=('9f699c59b95b6b33ed4d219d6f36ae4749e32b2817727649a9344bb9c2095742')

build() {
    cd "krellix-$pkgver"
    cmake -GNinja -B build -S . \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    cmake --build build --target krellpkg
}

package() {
    cd "krellix-$pkgver"
    install -Dm755 build/plugins/libkrellpkg.so \
        "$pkgdir/usr/lib/krellix/plugins/libkrellpkg.so"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
