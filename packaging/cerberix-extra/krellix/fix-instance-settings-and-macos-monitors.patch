+void seedMissingInstanceSettings(const QString &orgName, const QString &appName)
+{
+    const QString baseApp = QStringLiteral("krellix");
+    if (appName == baseApp)
+        return;
+
+    QSettings base(QSettings::IniFormat, QSettings::UserScope, orgName, baseApp);
+    if (base.allKeys().isEmpty())
+        return;
+
+    QSettings instance(QSettings::IniFormat, QSettings::UserScope, orgName, appName);
+    for (const QString &key : base.allKeys()) {
+        if (!instance.contains(key))
+            instance.setValue(key, base.value(key));
+    }
+    instance.sync();
+}
+
 } // namespace
 
