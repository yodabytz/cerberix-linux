# Maintainer: yodabytz <hello@cerberix.org>
pkgname=krellix-krellstack
pkgver=0.1.0
pkgrel=1
arch=('x86_64' 'aarch64')
url='https://github.com/yodabytz/krellix'
license=('GPL-3.0-or-later')
pkgdesc='KrellStack container stack monitor plugin for Krellix'
depends=('krellix>=0.1.0' 'qt6-base')
optdepends=('docker: Docker and Compose stack visibility'
            'podman: Podman container visibility'
            'kubectl: Kubernetes pod visibility')
makedepends=('cmake' 'ninja' 'qt6-tools' 'qt6-base')
options=('!debug')
source=("krellix-$pkgver.tar.gz")
sha256sums=('1b21f6a920de55672bc0cef8773f01ccc4aa9d1bd83f25c68d4631cb5ddeb47e')

build() {
    cd "krellix-$pkgver"
    cmake -GNinja -B build -S . \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    cmake --build build --target krellstack
}

package() {
    cd "krellix-$pkgver"
    install -Dm755 build/plugins/libkrellstack.so \
        "$pkgdir/usr/lib/krellix/plugins/libkrellstack.so"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
