# Maintainer: yodabytz <hello@cerberix.org>
pkgname=krellix-krellwire
pkgver=0.1.1
pkgrel=2
arch=('x86_64' 'aarch64')
url='https://github.com/yodabytz/krellix'
license=('GPL-3.0-or-later')
pkgdesc='Krellwire RSS headline ticker plugin for Krellix'
depends=('krellix>=0.1.1' 'qt6-base')
makedepends=('cmake' 'ninja' 'qt6-tools' 'qt6-base')
options=('!debug')
source=("krellix-$pkgver.tar.gz"
        "fix-plugin-id.patch")
sha256sums=('1c2d29205bb3749410e6288e8bb13d06b41ac3467687c80d14101d3c1073c3de'
            'SKIP')

prepare() {
    cd "krellix-$pkgver"
    patch -p1 < "$srcdir/fix-plugin-id.patch"
}

build() {
    cd "krellix-$pkgver"
    cmake -GNinja -B build -S . \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    cmake --build build --target krellwire
}

package() {
    cd "krellix-$pkgver"
    install -Dm755 build/plugins/libkrellwire.so \
        "$pkgdir/usr/lib/krellix/plugins/libkrellwire.so"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
