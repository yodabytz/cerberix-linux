+void KrellhealthMonitor::shutdown()
+{
+    m_updating = false;
+    m_pendingJobs.clear();
+    m_findings.clear();
+    QCoreApplication::removePostedEvents(this);
+
+    if (m_process) {
+        m_process->disconnect(this);
+        if (m_process->state() != QProcess::NotRunning)
+            m_process->kill();
+        m_process->deleteLater();
+        m_process = nullptr;
+    }
+
+    m_summary = nullptr;
+    m_detail = nullptr;
+    m_panel = nullptr;
+}
