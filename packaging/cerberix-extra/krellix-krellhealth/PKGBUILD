# Maintainer: yodabytz <hello@cerberix.org>
pkgname=krellix-krellhealth
pkgver=0.1.1
pkgrel=1
arch=('x86_64' 'aarch64')
url='https://github.com/yodabytz/krellix'
license=('GPL-3.0-or-later')
pkgdesc='KrellHealth compact system health monitor plugin for Krellix'
depends=('krellix>=0.1.1' 'qt6-base')
optdepends=('smartmontools: SMART disk health checks'
            'zfs-utils: ZFS pool health checks'
            'btrfs-progs: Btrfs device error checks'
            'openssl: local certificate expiry checks'
            'systemd: failed unit and time sync checks')
makedepends=('cmake' 'ninja' 'qt6-tools' 'qt6-base')
options=('!debug')
source=("krellix-$pkgver.tar.gz")
sha256sums=('dcc1bef431215d62d22f624c9a9ee229d92f792c26ac76c735da85a8867a6f4c')

build() {
    cd "krellix-$pkgver"
    cmake -GNinja -B build -S . \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    cmake --build build --target krellhealth
}

package() {
    cd "krellix-$pkgver"
    install -Dm755 build/plugins/libkrellhealth.so \
        "$pkgdir/usr/lib/krellix/plugins/libkrellhealth.so"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
