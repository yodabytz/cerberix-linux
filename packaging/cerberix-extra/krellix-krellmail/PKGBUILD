# Maintainer: yodabytz <hello@cerberix.org>
pkgname=krellix-krellmail
pkgver=0.1.1
pkgrel=2
arch=('x86_64' 'aarch64')
url='https://github.com/yodabytz/krellix'
license=('GPL-3.0-or-later')
pkgdesc='Krellmail POP3/IMAP mail count plugin for Krellix'
depends=('krellix>=0.1.1' 'qt6-base')
makedepends=('cmake' 'ninja' 'qt6-tools' 'qt6-base')
options=('!debug')
source=("krellix-$pkgver.tar.gz"
        "fix-closed-socket-read.patch")
sha256sums=('1c2d29205bb3749410e6288e8bb13d06b41ac3467687c80d14101d3c1073c3de'
            '67746e6e053d55a7be226f924b4fc7f9976b2fa00a9af52a9a520ee2a1b90989')

prepare() {
    cd "krellix-$pkgver"
    patch -Np1 -i "$srcdir/fix-closed-socket-read.patch"
}

build() {
    cd "krellix-$pkgver"
    cmake -GNinja -B build -S . \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    cmake --build build --target krellmail
}

package() {
    cd "krellix-$pkgver"
    install -Dm755 build/plugins/libkrellmail.so \
        "$pkgdir/usr/lib/krellix/plugins/libkrellmail.so"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
