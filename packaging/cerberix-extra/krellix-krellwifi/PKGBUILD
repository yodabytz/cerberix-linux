# Maintainer: yodabytz <hello@cerberix.org>
pkgname=krellix-krellwifi
pkgver=0.1.1
pkgrel=1
arch=('x86_64' 'aarch64')
url='https://github.com/yodabytz/krellix'
license=('GPL-3.0-or-later')
pkgdesc='KrellWiFi wireless analyzer plugin for Krellix'
depends=('krellix>=0.1.1' 'qt6-base')
optdepends=('networkmanager: nmcli WiFi scan backend')
makedepends=('cmake' 'ninja' 'qt6-tools' 'qt6-base')
options=('!debug')
source=("krellix-$pkgver.tar.gz")
sha256sums=('c8df5ccc19f362d88ff0e01ed51dd524c3b7b612b01b62f8b04552935a8de48d')

build() {
    cd "krellix-$pkgver"
    cmake -GNinja -B build -S . \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    cmake --build build --target krellwifi
}

package() {
    cd "krellix-$pkgver"
    install -Dm755 build/plugins/libkrellwifi.so \
        "$pkgdir/usr/lib/krellix/plugins/libkrellwifi.so"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
