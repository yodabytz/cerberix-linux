# Maintainer: yodabytz <hello@cerberix.org>
pkgname=krellix-krelldacious
pkgver=0.1.0
pkgrel=40
arch=('x86_64' 'aarch64')
url='https://github.com/yodabytz/krellix'
license=('GPL-3.0-or-later')
pkgdesc='Krelldacious Audacious playback/volume plugin for Krellix'
depends=('krellix>=0.1.0' 'qt6-base')
optdepends=('audacious: MPRIS player controlled by this plugin')
makedepends=('cmake' 'ninja' 'qt6-tools' 'qt6-base')
options=('!debug')
source=("krellix-$pkgver.tar.gz")
sha256sums=('49a257faf6f3a78fb9db4fa02c5114c2f2a4956b414c7c64ec5f4ffa393b7165')

build() {
    cd "krellix-$pkgver"
    cmake -GNinja -B build -S . \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    cmake --build build --target krelldacious
}

package() {
    cd "krellix-$pkgver"
    install -Dm755 build/plugins/libkrelldacious.so \
        "$pkgdir/usr/lib/krellix/plugins/libkrelldacious.so"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
